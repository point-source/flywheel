{
  "name": "flywheel",
  "version": "0.0.0",
  "private": true,
  "description": "GitHub Actions-native CI/CD orchestration layer for teams and AI agent swarms.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts --passWithNoTests",
    "test:e2e": "vitest run --config vitest.e2e.config.ts --passWithNoTests",
    "verify-dist": "node scripts/build.mjs && git diff --exit-code -- dist/"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@octokit/auth-app": "^8.2.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.2",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
