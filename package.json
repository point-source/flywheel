{
  "name": "swarmflow",
  "version": "0.0.0",
  "description": "Autonomous release pipeline as reusable GitHub Actions workflows",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "@octokit/auth-app": "^8.2.0",
    "release-please": "^16.15.0",
    "semver": "^7.6.3",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/semver": "^7.5.8",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "@vercel/ncc": "^0.38.2",
    "eslint": "^9.11.0",
    "globals": "^15.9.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.7.0",
    "undici": "^6.19.8",
    "vitest": "^2.1.1"
  },
  "lint-staged": {
    "**/*.ts": "eslint --fix"
  }
}
