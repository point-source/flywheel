# Adopter-supplied build workflow.
# The orchestrator dispatches this via workflow_dispatch with the inputs below.
# Replace the body of the build job with your real build steps.
#
# Identity: per spec.md ("Auth: GitHub App"), all bot-triggered downstream
# workflow dispatches must use the GitHub App installation token rather
# than GITHUB_TOKEN. Reuse the APP_ID / APP_PRIVATE_KEY repo secrets that
# the rest of the pipeline already expects.

name: pipeline / build

on:
  workflow_dispatch:
    inputs:
      version:
        description: 'Full semver string (e.g. 1.2.0-dev.3 or 1.2.0)'
        required: true
        type: string
      environment:
        description: 'develop | staging | production'
        required: true
        type: string
      changelog:
        description: Markdown changelog fragment for this version
        required: true
        type: string
      artifact_path:
        description: Where to write the build artifact
        required: false
        type: string
        default: dist/

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Build
        run: |
          mkdir -p ${{ inputs.artifact_path }}
          # Replace with your real build command, e.g.
          #   npm ci && npm run build
          #   cargo build --release
          #   go build -o "${{ inputs.artifact_path }}/myapp" ./cmd/myapp
          echo "TODO: build for version=${{ inputs.version }} env=${{ inputs.environment }}"

      - uses: actions/upload-artifact@v4
        with:
          name: build-${{ inputs.version }}
          path: ${{ inputs.artifact_path }}

      # Mint a short-lived App installation token so the publish dispatch
      # is attributed to the pipeline bot identity rather than the runner.
      - id: token
        uses: actions/create-github-app-token@v1
        with:
          app-id: ${{ secrets.APP_ID }}
          private-key: ${{ secrets.APP_PRIVATE_KEY }}

      # Chain into publish on success.
      - name: Trigger publish
        env:
          GH_TOKEN: ${{ steps.token.outputs.token }}
        run: |
          gh workflow run pipeline-publish.yml \
            -f version='${{ inputs.version }}' \
            -f environment='${{ inputs.environment }}' \
            -f changelog='${{ inputs.changelog }}' \
            -f artifact_path='${{ inputs.artifact_path }}'
